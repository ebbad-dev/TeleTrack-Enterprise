# ═══════════════════════════════════════════════════════════════════
# TeleTrack Enterprise — Environment Configuration Template
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-secure-random-string

# Database (PostgreSQL)
DATABASE_URL=postgresql://teletrack:teletrack_pass@localhost:5432/teletrack_db

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATELIMIT_STORAGE_URL=redis://localhost:6379/1

# SMTP (Phase 3)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@teletrack.com

# Twilio (Phase 3)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=logs/teletrack.log
