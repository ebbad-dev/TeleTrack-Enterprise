# TeleTrack Enterprise — Development Environment
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=teletrack-dev-secret-key-change-in-production-2026

# PostgreSQL (Docker Compose)
# For PostgreSQL (when Docker is available):
# DATABASE_URL=postgresql://teletrack:teletrack_pass@localhost:5432/teletrack_db

# SQLite for local development (no external dependencies):
DATABASE_URL=sqlite:///teletrack.db

# JWT
JWT_SECRET_KEY=teletrack-jwt-dev-secret-2026-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Redis (Docker Compose)
# Redis (when Docker is available):
# REDIS_URL=redis://localhost:6379/0

# CORS (Vite dev server)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATELIMIT_STORAGE_URL=memory://

# Logging
LOG_LEVEL=DEBUG
